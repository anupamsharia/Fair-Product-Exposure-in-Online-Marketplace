# FairCart - Production Environment Variables
# Copy this file to .env and fill in the values

# MongoDB Configuration
MONGO_URI=your_mongodb_connection_string_here

# OpenAI API Key (for AI features)
OPENAI_API_KEY=your_openai_api_key_here

# Internal service API key (only for protected internal endpoints)
INTERNAL_API_KEY=generate_internal_api_key_here

# Google Cloud Vision (optional, for image moderation)
GOOGLE_APPLICATION_CREDENTIALS=path/to/vision-key.json

# Admin Credentials (change in production!)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=strong_password_here

# Flask Configuration
SECRET_KEY=generate_a_secure_random_key_here
FLASK_ENV=production

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://yourdomain.com

# Server Configuration (optional)
HOST=0.0.0.0
PORT=5000

# Cache Configuration
CACHE_TTL_PRODUCTS=300
CACHE_TTL_ML_SCORES=600

# Logging Level
LOG_LEVEL=INFO

# Rate Limiting (requests per minute)
RATE_LIMIT=100
